---
// Étend le PageTitle Starlight par défaut pour insérer le fil d'Ariane
// (Breadcrumb) juste au-dessus du h1 — reproduit la position du fil
// d'Ariane DSFR, entre la barre de sections et le titre de page.
import Breadcrumb from './Breadcrumb.astro';

// Valeur figée de `PAGE_TITLE_ID` dans @astrojs/starlight/constants — non
// exportée via un sous-chemin package.json, donc reprise ici en dur.
const PAGE_TITLE_ID = '_top';

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const { entry } = (Astro.locals as any).starlightRoute;
---

<Breadcrumb />
<h1 id={PAGE_TITLE_ID}>{entry.data.title}</h1>

<style>
  h1 {
    margin-top: 1rem;
    font-size: var(--sl-text-h1);
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-white);
  }
</style>
