---
// Fil d'Ariane "Accueil > Section [> Page]", rendu au-dessus du titre de
// page (voir PageTitle.astro) — reproduit le fil d'Ariane du DSFR, absent
// de Starlight par défaut. La section active est retrouvée de la même
// façon que SectionNav/Sidebar, via SECTION_PREFIXES.
import { SECTION_PREFIXES } from './section-prefixes';

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const { sidebar, entry } = (Astro.locals as any).starlightRoute;
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;

const groups = sidebar.filter((item: { type: string }) => item.type === 'group');

const activeIndex = groups.findIndex((_group: unknown, i: number) => {
  const prefix = SECTION_PREFIXES[i];
  return prefix && pathname.includes(`/${prefix}/`);
});
const activeGroup = activeIndex >= 0 ? groups[activeIndex] : null;
const prefix = activeIndex >= 0 ? SECTION_PREFIXES[activeIndex] : null;
const sectionHref = prefix ? `${base}${prefix}/` : undefined;
const isSectionLanding = sectionHref ? pathname === sectionHref : false;
---

{
  activeGroup && (
    <nav class="tds-breadcrumb print:hidden" aria-label="Fil d'Ariane">
      <ol>
        <li>
          <a href={base}>Accueil</a>
        </li>
        <li>
          {isSectionLanding ? (
            <span aria-current="page">{activeGroup.label}</span>
          ) : (
            <a href={sectionHref}>{activeGroup.label}</a>
          )}
        </li>
        {!isSectionLanding && (
          <li>
            <span aria-current="page">{entry.data.title}</span>
          </li>
        )}
      </ol>
    </nav>
  )
}

<style>
  .tds-breadcrumb {
    margin-top: 1rem;
  }

  .tds-breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }

  .tds-breadcrumb li:not(:last-child)::after {
    content: '›';
    margin: 0 0.4em;
  }

  .tds-breadcrumb a {
    color: var(--sl-color-gray-2);
    text-decoration: underline;
  }

  .tds-breadcrumb a:hover,
  .tds-breadcrumb a:focus {
    color: var(--sl-color-white);
  }

  .tds-breadcrumb [aria-current='page'] {
    color: var(--sl-color-gray-3);
  }
</style>
