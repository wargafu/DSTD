---
// Étend le Footer Starlight par défaut avec le bandeau institutionnel de bas de
// page, dans l'esprit du DSFR (Système de Design de l'État français) :
// accessibilité, mentions légales, plan du site, cookies, affichage.
import Default from '@astrojs/starlight/components/Footer.astro';

const base = import.meta.env.BASE_URL;
const links = [
  { label: 'Accessibilité : non conforme', href: 'about/accessibilite/' },
  { label: 'Conditions générales d\'utilisation', href: 'about/cgu/' },
  { label: 'Mentions légales', href: 'about/mentions-legales/' },
  { label: 'Plan du site', href: 'about/plan-du-site/' },
  { label: 'Gestion des cookies', href: 'about/cookies/' },
  { label: 'Paramètres d\'affichage', href: 'about/parametres-affichage/' },
];
---

<Default><slot /></Default>

<div class="tds-institutional-footer">
  <nav aria-label="Informations légales">
    <ul>
      {links.map((link) => (
        <li><a href={`${base}${link.href}`}>{link.label}</a></li>
      ))}
    </ul>
  </nav>
</div>

<style>
  .tds-institutional-footer {
    border-top: 1px solid var(--sl-color-gray-5);
    padding: 1rem 1.5rem;
  }

  .tds-institutional-footer nav {
    max-width: var(--sl-content-width);
    margin-inline: auto;
  }

  .tds-institutional-footer ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tds-institutional-footer a {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-decoration: none;
  }

  .tds-institutional-footer a:hover {
    color: var(--sl-color-white);
    text-decoration: underline;
  }
</style>
