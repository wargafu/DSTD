# Force LF on all text files for cross-platform consistency
* text=auto eol=lf

# Explicitly LF
*.ts    text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.mdx   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.html  text eol=lf
*.svg   text eol=lf

# Binary — ne pas toucher
*.woff2 binary
*.png   binary
*.jpg   binary
*.ico   binary
